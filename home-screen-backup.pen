                },
                {
                  "type": "text",
                  "id": "lOJFq",
                  "name": "piiDesc",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": 800,
                  "content": "Antes de procesar cualquier correo, la app elimina de tu telefono:\n• Direcciones de correo electronico\n• Numeros de telefono\n• Numeros de tarjeta de credito o debito\n\nEl correo original completo nunca se guarda ni se envia a ningun lugar.",
                  "lineHeight": 1.6,
                  "fontFamily": "Poppins",
                  "fontSize": 16,
                  "fontWeight": "500"
                },
                {
