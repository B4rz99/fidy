                },
                {
                  "type": "text",
                  "id": "L0qJC",
                  "name": "tpDesc",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": 800,
                  "content": "• OpenAI — Lee el texto limpio (sin datos personales) para identificar tus transacciones\n• Nube segura — Respalda tus transacciones para que no las pierdas\n• Google / Microsoft — Acceso de solo lectura a tu correo",
                  "lineHeight": 1.6,
                  "fontFamily": "Poppins",
