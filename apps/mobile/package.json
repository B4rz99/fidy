{
  "name": "@fidy/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run stryker.conf.json",
    "bundle:atlas": "EXPO_UNSTABLE_ATLAS=true expo export --platform ios --output-dir dist/export",
    "bundle:atlas:open": "expo-atlas .expo/atlas.jsonl",
    "build:dev": "eas build --profile development --platform all",
    "build:preview": "eas build --profile preview --platform all",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:prod": "eas build --profile production --platform all"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/ui": "^56.0.4",
    "@fidy/assets": "workspace:*",
    "@fidy/schemas": "workspace:*",
    "@fidy/types": "workspace:*",
    "@fidy/utils": "workspace:*",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-vector-icons/ionicons": "^13.1.1",
    "@react-native-vector-icons/material-icons": "^13.1.1",
    "@sentry/cli": "3.4.1",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "2.105.1",
    "@tanstack/react-query": "5.100.1",
    "burnt": "^0.13.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "0.45.2",
    "effect": "3.21.2",
    "expo": "56.0.0-preview.7",
    "expo-android-notification-listener-service": "^1.1.0",
    "expo-background-task": "~56.0.5",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.6",
    "expo-crypto": "~56.0.3",
    "expo-dev-client": "~56.0.5",
    "expo-font": "~56.0.3",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.4",
    "expo-linking": "~56.0.4",
    "expo-localization": "~56.0.3",
    "expo-navigation-bar": "^56.0.3",
    "expo-notifications": "~56.0.5",
    "expo-router": "~56.1.1",
    "expo-secure-store": "~56.0.3",
    "expo-splash-screen": "~56.0.4",
    "expo-sqlite": "~56.0.3",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.4",
    "expo-task-manager": "~56.0.5",
    "expo-updates": "~56.0.6",
    "expo-web-browser": "~56.0.4",
    "i18n-js": "^4.5.3",
    "lucide-react-native": "1.14.0",
    "nativewind": "^4",
    "posthog-react-native": "4.44.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-css-interop": "^0.2.3",
