{
  "name": "@fidy/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client --host lan --port 8081",
    "android": "expo run:android",
    "ios": "expo run:ios --device \"iPhone 17 Pro\"",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:crap": "vitest run --config vitest.crap.config.ts --coverage && node scripts/normalize-crap-coverage.mjs && crap4ts --coverage coverage/crap-normalized-coverage-final.json --strict",
    "test:mutation": "stryker run stryker.conf.json",
    "bundle:atlas": "EXPO_UNSTABLE_ATLAS=true expo export --platform ios --output-dir dist/export",
    "bundle:atlas:open": "expo-atlas .expo/atlas.jsonl",
    "build:dev": "eas build --profile development --platform all",
    "build:preview": "eas build --profile preview --platform all",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:prod": "eas build --profile production --platform all"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@fidy/assets": "workspace:*",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "2.9.15",
    "@react-navigation/native": "7.3.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "2.108.1",
    "@tanstack/react-query": "5.101.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "0.45.2",
    "effect": "3.21.0",
    "expo": "~55.0.27",
    "expo-android-notification-listener-service": "^1.1.0",
    "expo-background-task": "~55.0.19",
    "expo-blur": "~55.0.15",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.16",
    "expo-dev-client": "~55.0.36",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.15",
    "expo-image": "~55.0.11",
    "expo-linking": "~55.0.16",
    "expo-localization": "~55.0.16",
    "expo-notifications": "~55.0.24",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.15",
    "expo-splash-screen": "~55.0.22",
    "expo-sqlite": "~55.0.17",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.19",
    "expo-task-manager": "~55.0.17",
    "expo-updates": "~55.0.25",
    "expo-web-browser": "~55.0.17",
    "i18n-js": "^4.5.3",
    "lucide-react-native": "1.18.0",
    "nativewind": "^4",
    "posthog-react-native": "4.47.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-css-interop": "^0.2.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "tailwindcss": "3.4.19",
    "zod": "^4.4.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "7.29.7",
    "@stryker-mutator/core": "9.6.0",
    "@testing-library/react-native": "14.0.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/react": "~19.2.10",
    "@vitest/coverage-v8": "4.1.7",
    "babel-preset-expo": "~55.0.8",
    "better-sqlite3": "12.10.0",
    "crap4ts": "^1.0.1",
    "drizzle-kit": "0.31.9",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.1",
    "eslint-plugin-boundaries": "6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "expo-atlas": "0.4.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.7"
  },
  "expo": {
    "install": {
      "exclude": [
        "@react-navigation/native"
      ]
    }
  }
}
