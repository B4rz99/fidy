{
  "name": "fidy-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "bun run --cwd apps/mobile --shell=bun start",
    "mobile:ios": "bun run --cwd apps/mobile --shell=bun ios",
    "mobile:android": "bun run --cwd apps/mobile --shell=bun android",
    "mobile:web": "bun run --cwd apps/mobile --shell=bun web",
    "qa:ios": "bun ./scripts/mobile-qa.ts ios",
    "qa:reset": "bun ./scripts/mobile-qa.ts reset",
    "qa:seed": "bun ./scripts/mobile-qa.ts seed",
    "qa:open": "bun ./scripts/mobile-qa.ts open",
    "qa:smoke": "bun ./scripts/mobile-qa.ts smoke",
    "sim:serve": "bunx serve-sim --detach",
    "sim:serve:list": "bunx serve-sim --list",
    "sim:serve:kill": "bunx serve-sim --kill",
    "analyze:complexity:strict:update-ledger": "bun ./scripts/run-lizard-strict.ts --write-ledger",
    "analyze:file-size": "bun ./scripts/check-max-file-lines.ts",
    "mcp:xcodebuild": "xcodebuildmcp mcp",
    "landing": "bun run --cwd apps/landing --shell=bun dev",
    "build:packages": "bun run --cwd packages/assets --shell=bun build && bun run --cwd packages/types --shell=bun build && bun run --cwd packages/schemas --shell=bun build && bun run --cwd packages/utils --shell=bun build",
    "lint:mobile": "bun run --cwd apps/mobile --shell=bun lint",
    "lint:complexity": "bun ./scripts/run-lizard-strict.ts",
    "lint:file-size": "bun ./scripts/check-max-file-lines.ts --enforce",
    "lint:theme-colors": "bun ./scripts/check-theme-color-literals.ts --enforce",
    "lint:dependency-policy": "bun ./scripts/check-dependency-policy.ts --enforce --stale-days 365",
    "lint:brands": "bun scripts/check-branded-boundaries.ts",
    "lint:feature-public-imports": "bun ./scripts/check-feature-public-imports.ts --enforce",
    "lint:mobile-ui-architecture": "bun ./scripts/check-mobile-ui-architecture.ts",
    "lint:architecture": "bun test ./scripts/dependency-cruiser-config.test.ts && bun run lint:feature-public-imports && bun run lint:mobile-ui-architecture && bunx dependency-cruiser --config .dependency-cruiser.cjs apps/mobile packages",
    "typecheck:packages": "bun run --cwd packages/assets --shell=bun typecheck && bun run --cwd packages/types --shell=bun typecheck && bun run --cwd packages/schemas --shell=bun typecheck && bun run --cwd packages/utils --shell=bun typecheck",
    "typecheck": "bun run build:packages && bun run typecheck:packages && bun run --cwd apps/mobile --shell=bun typecheck",
    "test:mobile": "bun run --cwd apps/mobile --shell=bun test",
    "test:mutation:mobile": "bun run --cwd apps/mobile --shell=bun test:mutation",
    "test": "bun run test:mobile",
    "test:coverage": "bun run --cwd apps/mobile --shell=bun test:coverage",
    "test:crap": "bun run --cwd apps/mobile --shell=bun test:crap",
    "perf:bundle:mobile": "bun run --cwd apps/mobile --shell=bun bundle:atlas",
    "doctor:expo": "bunx expo-doctor apps/mobile",
    "doctor:react": "git fetch origin main --depth=1 && bunx react-doctor . --offline --diff origin/main --verbose --project @fidy/mobile --blocking warning",
    "lint": "bunx oxlint .",
    "lint:oxc:strict": "bunx oxlint --config .oxlintrc.strict.json .",
    "lint:oxc:type-aware": "bunx oxlint --config .oxlintrc.strict.json --type-aware .",
    "format": "bunx oxfmt --write .",
    "format:check": "bunx oxfmt --check .",
    "verify": "bun run lint && bun run lint:brands && bun run lint:mobile && bun run lint:complexity && bun run lint:file-size && bun run lint:theme-colors && bun run lint:dependency-policy && bun run lint:architecture && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "bun-types": "1.3.13",
    "dependency-cruiser": "17.4.0",
    "expo-doctor": "^1.19.8",
    "lefthook": "2.1.6",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0",
    "react-doctor": "0.5.1",
    "serve-sim": "0.1.36",
    "typescript": "6.0.3",
    "xcodebuildmcp": "2.5.2"
  },
  "resolutions": {
    "@esbuild-kit/core-utils/esbuild": "0.25.0",
    "@eslint/config-array/minimatch/brace-expansion": "1.1.13",
    "@eslint/eslintrc/minimatch/brace-expansion": "1.1.13",
    "@expo/cli/ws": "8.20.1",
    "@react-native/codegen/glob/minimatch/brace-expansion": "1.1.13",
    "@react-native/community-cli-plugin/metro-config/yaml": "2.8.3",
    "@react-navigation/core": "7.19.0",
    "@react-navigation/native": "7.3.0",
    "@xmldom/xmldom": "0.8.13",
    "anymatch/picomatch": "2.3.2",
    "brace-expansion": "5.0.6",
    "drizzle-kit/esbuild": "0.25.4",
    "eslint-plugin-import/minimatch/brace-expansion": "1.1.13",
    "eslint-plugin-react/minimatch/brace-expansion": "1.1.13",
    "eslint/minimatch/brace-expansion": "1.1.13",
    "flatted": "3.4.2",
    "jest-util/picomatch": "2.3.2",
    "js-yaml": "4.2.0",
    "metro-config/yaml": "2.8.3",
    "micromatch/picomatch": "2.3.2",
    "node-forge": "1.4.0",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "react-native/glob/minimatch/brace-expansion": "1.1.13",
    "rimraf/glob/minimatch/brace-expansion": "1.1.13",
    "shell-quote": "1.8.4",
    "tailwindcss/chokidar/readdirp/picomatch": "2.3.2",
    "test-exclude/minimatch/brace-expansion": "1.1.13",
    "tinyglobby/picomatch": "4.0.4",
    "vite": "8.0.16",
    "vite/esbuild": "0.28.1",
    "vite/picomatch": "4.0.4",
    "vitest/picomatch": "4.0.4",
    "ws": "8.21.0",
    "yaml": "2.8.3"
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "@opentelemetry/core": "2.8.0",
    "@react-navigation/core": "7.19.0",
    "@react-navigation/native": "7.3.0",
    "esbuild": "0.28.1",
    "fast-uri": "3.1.2",
    "hono": "4.12.25",
    "ip-address": "10.1.1",
    "js-yaml": "4.2.0",
    "lodash": "4.18.1",
    "qs": "6.15.2",
    "shell-quote": "1.8.4",
    "uuid": "14.0.0",
    "vite": "8.0.16",
    "ws": "8.21.0"
  },
  "packageManager": "bun@1.3.13",
  "patchedDependencies": {
    "@expo/cli@55.0.32": "patches/@expo%2Fcli@55.0.32.patch"
  }
}
