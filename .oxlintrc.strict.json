{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "react", "vitest", "promise"],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.expo/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/.ocx/**",
    "**/.continue/**",
    "**/.kiro/**",
    "**/.windsurf/**",
    "apps/mobile/android/**",
    "apps/mobile/ios/**",
    "apps/mobile/coverage/**"
  ],
  "rules": {
    "array-callback-return": "error",
    "curly": ["error", "multi-line"],
    "default-case-last": "error",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "jest/expect-expect": "off",
    "jest/no-conditional-expect": "off",
    "jest/no-disabled-tests": "off",
    "jest/no-export": "off",
    "jest/no-focused-tests": "off",
    "jest/no-standalone-expect": "off",
    "jest/prefer-snapshot-hint": "off",
    "jest/require-to-throw-message": "off",
    "jest/valid-describe-callback": "off",
    "jest/valid-expect": "off",
    "jest/valid-expect-in-promise": "off",
    "jest/valid-title": "off",
    "import/first": "error",
    "import/no-cycle": "error",
    "no-console": "error",
    "no-constant-binary-expression": "error",
    "no-duplicate-imports": ["error", { "allowSeparateTypeImports": true }],
    "no-else-return": "error",
    "no-fallthrough": "error",
    "no-implicit-coercion": "error",
    "no-implied-eval": "error",
    "no-lonely-if": "error",
    "no-nested-ternary": "error",
    "no-param-reassign": "error",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "react",
            "importNames": ["useEffect", "useLayoutEffect"],
            "message": "useEffect/useLayoutEffect are banned. Use approved hooks from @/shared/hooks instead."
          }
        ],
        "patterns": [
          "@/features/*/lib/*",
          "@/features/*/components/*",
          "@/features/*/hooks/*",
          "@/features/*/store",
          "@/features/*/schema",
          "@/features/*/services/*",
          "@/shared/lib/*",
          "@/shared/db/*",
          "react-native",
          "lucide-react-native"
        ]
      }
    ],
    "no-self-compare": "error",
    "no-unneeded-ternary": "error",
    "no-useless-catch": "error",
    "no-useless-return": "error",
    "no-var": "error",
    "object-shorthand": ["error", "always"],
    "prefer-const": "error",
    "prefer-object-has-own": "error",
    "prefer-object-spread": "error",
    "radix": "error",
    "react/rules-of-hooks": "error",
    "typescript/await-thenable": "error",
    "typescript/consistent-type-imports": [
      "error",
      { "prefer": "type-imports", "fixStyle": "inline-type-imports" }
    ],
    "typescript/no-explicit-any": "error",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-redundant-type-constituents": "error",
    "typescript/no-require-imports": "error",
    "typescript/no-unnecessary-condition": "error",
    "typescript/no-unnecessary-type-assertion": "error",
    "typescript/no-unsafe-argument": "error",
    "typescript/no-unsafe-assignment": "error",
    "typescript/no-unsafe-call": "error",
    "typescript/no-unsafe-member-access": "error",
    "typescript/no-unsafe-return": "error",
    "typescript/only-throw-error": "error",
    "typescript/prefer-nullish-coalescing": "error",
    "typescript/prefer-optional-chain": "error",
    "typescript/restrict-template-expressions": "error",
    "typescript/switch-exhaustiveness-check": "error",
    "yoda": "error"
  },
  "overrides": [
    {
      "files": ["**/__tests__/**/*.ts", "**/__tests__/**/*.tsx", "**/*.test.ts", "**/*.test.tsx"],
      "rules": {
        "typescript/no-explicit-any": "warn",
        "typescript/no-non-null-assertion": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-return": "off",
        "typescript/restrict-template-expressions": "off",
        "no-restricted-imports": "off"
      }
    },
    {
      "files": ["scripts/**/*.ts", "*.cjs", "*.js", "apps/mobile/*.js", "apps/landing/**/*.js"],
      "rules": {
        "no-console": "off",
        "no-var": "off",
        "object-shorthand": "off",
        "typescript/no-require-imports": "off"
      }
    },
    {
      "files": ["apps/mobile/shared/hooks/**/*.ts", "apps/mobile/shared/hooks/**/*.tsx"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
