{
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "target": "ESNext",
    "module": "ESNext",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/mobile/*"],
      "@fidy/assets": ["packages/assets/src/index.ts"],
      "@fidy/types": ["packages/types/src/index.ts"],
      "@fidy/schemas": ["packages/schemas/src/index.ts"],
      "@fidy/utils": ["packages/utils/src/index.ts"]
    }
  },
  "include": [
    "apps/mobile/**/*.ts",
    "apps/mobile/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "apps/mobile/.expo/**",
    "apps/mobile/android/**",
    "apps/mobile/ios/**"
  ]
}
