{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"$CODEX_PROJECT_DIR\"/.ai-security/hooks/post-tool-defender.ts",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"$CODEX_PROJECT_DIR\"/.ai-security/hooks/post-tool-defender.ts",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"$CODEX_PROJECT_DIR\"/.ai-security/hooks/post-tool-defender.ts",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
